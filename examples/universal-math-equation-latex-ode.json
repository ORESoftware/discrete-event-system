        "ports": {
          "inputs": ["y"],
          "outputs": ["out"]
        }
      }
    ],
    "movingEntities": [
      {
        "id": "MathSignal",
        "kind": "signal-token",
        "tokenType": "MathSignal",
        "payloadSchema": {
          "value": "number",
          "time": "number",
          "tick": "integer",
          "sourceId": "string",
          "channel": "string"
        },
        "semantics": "Scalar value token moving between stationary math blocks."
      }
    ],
    "graph": {
      "nodes": [
        {
          "id": "integrator:y",
          "kind": "integrator",
          "role": "integrator",
          "className": "IntegratorBlock",
          "parameters": {
            "initialState": 1,
            "method": "euler"
          },
          "ports": {
            "inputs": ["in"],
            "outputs": ["out"]
          }
        },
        {
          "id": "rhs:y",
          "kind": "expression",
          "role": "processor",
          "className": "ExpressionBlock",
          "parameters": {
            "expression": "-k*y"
          },
          "ports": {
            "inputs": ["y"],
            "outputs": ["out"]
          }
        }
      ],
      "edges": [
        {
          "id": "edge:state-to-rhs",
          "from": {
            "entityId": "integrator:y",
            "port": "out"
          },
          "to": {
            "entityId": "rhs:y",
            "port": "y"
          },
          "movingEntity": "MathSignal"
        },
        {
          "id": "edge:rhs-to-integrator",
          "from": {
            "entityId": "rhs:y",
            "port": "out"
          },
          "to": {
            "entityId": "integrator:y",
            "port": "in"
          },
          "movingEntity": "MathSignal"
        }
