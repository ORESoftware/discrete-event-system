        "id": "t",
        "role": "independent"
      }
    ],
    "stateVariables": [
      {
        "id": "y",
        "role": "state",
        "initial": 1
      }
    ],
    "parameters": [
      {
        "id": "k",
        "value": 1
      }
    ],
    "equations": [
      {
        "id": "ode:y",
        "kind": "ode",
        "lhs": "dy/dt",
        "rhs": "-k*y",
        "normalizedExpression": "-k*y",
        "variables": ["y"]
      }
    ],
    "initialConditions": [
      {
        "id": "initial:y",
        "variable": "y",
        "at": {
          "t": 0
        },
        "value": 1,
        "kind": "initial"
      }
    ],
    "numerics": {
      "time": {
        "t0": 0,
        "t1": 1,
        "dt": 0.01,
        "steps": 100
      },
      "method": "euler"
    },
    "normalized": {
      "targetModel": "math-equation",
      "parameters": {
        "format": "latex",
        "kind": "ode",
        "equation": "\\frac{dy}{dt} = -k y; y(0)=1",
        "constants": {
          "k": 1
        },
        "t0": 0,
        "t1": 1,
        "dt": 0.01,
        "method": "euler"
      }
    }
  },
  "des": {
    "time": {
      "t0": 0,
      "t1": 1,
      "dt": 0.01,
      "steps": 100
    },
    "stationaryEntities": [
      {
        "id": "integrator:y",
        "kind": "integrator",
        "role": "integrator",
        "className": "IntegratorBlock",
        "parameters": {
          "initialState": 1,
          "method": "euler"
        },
        "ports": {
          "inputs": ["in"],
          "outputs": ["out"]
        }
      },
      {
        "id": "rhs:y",
        "kind": "expression",
        "role": "processor",
        "className": "ExpressionBlock",
        "parameters": {
          "expression": "-k*y"
