{
  "$schema": "des/model-spec/v1",
  "model": "neural-qlearning-corridor",
  "description": "Learn a corridor MDP with a neural Q-function inside the DES environment-agent loop.",
  "parameters": {
    "length": 6,
    "numEpisodes": 600,
    "maxStepsPerEpisode": 40,
    "alpha": 0.25,
    "gamma": 0.95,
    "epsilon": 0.8,
    "epsilonDecay": 0.99,
    "epsilonMin": 0.02,
    "seed": 1,
    "hiddenLayers": []
  },
  "runtime": {
    "verbose": true,
    "outputs": {
      "html": "out/neural-qlearning-corridor.html",
      "frames": "out/neural-qlearning-corridor.frames.jsonl",
      "summary": "out/neural-qlearning-corridor-summary.json"
    }
  }
}
