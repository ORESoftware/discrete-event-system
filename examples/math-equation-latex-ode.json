{
  "$schema": "des/model-spec/v1",
  "model": "math-equation",
  "description": "LaTeX ODE input normalized into a stationary math-block network.",
  "parameters": {
    "format": "latex",
    "kind": "ode",
    "equation": "\\frac{dy}{dt} = -k y; y(0)=1",
    "constants": {
      "k": 1
    },
    "t0": 0,
    "t1": 1,
    "dt": 0.01,
    "method": "euler"
  },
  "runtime": {
    "animate": true,
    "outputs": {
      "csv": "out/math-equation-latex-ode.csv",
      "html": "out/math-equation-latex-ode.html",
      "log": "out/math-equation-latex-ode.jsonl",
      "summary": "out/math-equation-latex-ode-summary.json"
    }
  },
  "metadata": {
    "tags": ["math-equation", "latex", "ode"]
  }
}
